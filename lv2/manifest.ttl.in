@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ui:   <http://lv2plug.in/ns/extensions/ui#> .

<http://deimos.ca/neuralblender>
    a lv2:Plugin ;
    lv2:binary <neuralblender.so> ;
    rdfs:seeAlso <neuralblender.ttl> .

@@UI<http://deimos.ca/neuralblender#ui>
@@UI    a ui:X11UI ;
@@UI    ui:binary <neuralblender_ui.so> ;
@@UI    rdfs:seeAlso <neuralblender.ttl> .
