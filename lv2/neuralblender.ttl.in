@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix patch: <http://lv2plug.in/ns/ext/patch#> .
@prefix urid:  <http://lv2plug.in/ns/ext/urid#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix mod:   <http://moddevices.com/ns/mod#> .
@prefix nb:    <http://deimos.ca/neuralblender#> .
@prefix state: <http://lv2plug.in/ns/ext/state#> .
@prefix pprop: <http://lv2plug.in/ns/ext/port-props#> .

nb:ModelA
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json" ;
    rdfs:label "Model A" ;
    rdfs:range atom:Path .

nb:ModelB
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json" ;
    rdfs:label "Model B" ;
    rdfs:range atom:Path .

nb:ModelC
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json" ;
    rdfs:label "Model C" ;
    rdfs:range atom:Path .

nb:ModelD
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json" ;
    rdfs:label "Model D" ;
    rdfs:range atom:Path .

nb:PedalA
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json,wav,flac,aiff,aif" ;
    rdfs:label "Pedal A" ;
    rdfs:range atom:Path .

nb:PedalB
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json,wav,flac,aiff,aif" ;
    rdfs:label "Pedal B" ;
    rdfs:range atom:Path .

nb:PedalC
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json,wav,flac,aiff,aif" ;
    rdfs:label "Pedal C" ;
    rdfs:range atom:Path .

nb:PedalD
    a lv2:Parameter ;
    mod:fileTypes "nam,aidax,json,wav,flac,aiff,aif" ;
    rdfs:label "Pedal D" ;
    rdfs:range atom:Path .

nb:CabA
    a lv2:Parameter ;
    mod:fileTypes "wav,flac,aiff,aif,nam,aidax,json" ;
    rdfs:label "Cab/IR A" ;
    rdfs:range atom:Path .

nb:CabB
    a lv2:Parameter ;
    mod:fileTypes "wav,flac,aiff,aif,nam,aidax,json" ;
    rdfs:label "Cab/IR B" ;
    rdfs:range atom:Path .

nb:CabC
    a lv2:Parameter ;
    mod:fileTypes "wav,flac,aiff,aif,nam,aidax,json" ;
    rdfs:label "Cab/IR C" ;
    rdfs:range atom:Path .

nb:CabD
    a lv2:Parameter ;
    mod:fileTypes "wav,flac,aiff,aif,nam,aidax,json" ;
    rdfs:label "Cab/IR D" ;
    rdfs:range atom:Path .

<http://deimos.ca/neuralblender>
    a lv2:Plugin ,
      lv2:AmplifierPlugin ;

    lv2:requiredFeature urid:map ;
    lv2:extensionData state:interface ;
    ui:ui <http://deimos.ca/neuralblender#ui> ;

	    patch:readable nb:ModelA ,
		                   nb:ModelB ,
		                   nb:ModelC ,
		                   nb:ModelD ,
		                   nb:PedalA ,
		                   nb:PedalB ,
		                   nb:PedalC ,
		                   nb:PedalD ,
		                   nb:CabA ,
		                   nb:CabB ,
		                   nb:CabC ,
		                   nb:CabD ;
	    patch:writable nb:ModelA ,
		                   nb:ModelB ,
		                   nb:ModelC ,
		                   nb:ModelD ,
		                   nb:PedalA ,
		                   nb:PedalB ,
		                   nb:PedalC ,
		                   nb:PedalD ,
		                   nb:CabA ,
		                   nb:CabB ,
		                   nb:CabC ,
		                   nb:CabD ;
    
    doap:name "NeuralBlender" ;
    doap:developer [
        a foaf:Organization ;
        foaf:name "DeimosLabs"
    ] ;
    doap:maintainer [
        a foaf:Organization ;
        foaf:name "DeimosLabs"
    ] ;

    lv2:port [
        a lv2:InputPort ,
          lv2:AudioPort ;
        lv2:index 0 ;
        lv2:symbol "audio_in" ;
        lv2:name "Audio In"
    ] , [
        a lv2:OutputPort ,
          lv2:AudioPort ;
        lv2:index 1 ;
        lv2:symbol "audio_out" ;
        lv2:name "Audio Out"
    ] , [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 2 ;
        lv2:symbol "bypass" ;
        lv2:name "ENABLE" ;
        lv2:designation lv2:enabled ;
        lv2:portProperty lv2:toggled ;
        lv2:default 1 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] , [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 3 ;
        lv2:symbol "a_gain_in" ;
        lv2:name "A Input Gain" ;
        lv2:default 0.0 ;
        lv2:minimum -40.0 ;
        lv2:maximum 40.0
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "a_ir_pitch" ;
        lv2:name "A IR Pitch" ;
        lv2:default 0.0 ;
        lv2:minimum -12.0 ;
        lv2:maximum 12.0
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "a_gain_out" ;
        lv2:name "A Output Gain" ;
        lv2:default 0.0 ;
        lv2:minimum -40.0 ;
        lv2:maximum 40.0
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 6 ;
        lv2:symbol "a_dry_out" ;
        lv2:name "A Dry Out" ;
        lv2:default -120.0 ;
        lv2:minimum -120.0 ;
        lv2:maximum 12.0
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 7 ;
        lv2:symbol "a_delay" ;
        lv2:name "A Delay (ms)" ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 30
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 8 ;
        lv2:symbol "a_mute" ;
        lv2:name "A Mute" ;
        lv2:portProperty lv2:toggled ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 9 ;
        lv2:symbol "a_dcflip" ;
        lv2:name "A Phase Flip" ;
        lv2:portProperty lv2:toggled ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] ,
    [
        a lv2:InputPort ,
          lv2:ControlPort ;
        lv2:index 10 ;
        lv2:symbol "a_calibrate" ;
        lv2:name "A Normalize Level" ;
        lv2:portProperty lv2:toggled ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1
    ] ,
    [
        a lv2:InputPort ,
